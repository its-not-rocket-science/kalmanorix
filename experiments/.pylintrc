[MESSAGES CONTROL]
disable=too-few-public-methods,
    too-many-arguments,
    too-many-locals,
    invalid-name,
    too-many-positional-arguments,
    import-error,
    abstract-class-instantiated,
    duplicate-code,
    line-too-long,
    missing-final-newline,
    missing-function-docstring,
    missing-class-docstring,
    unnecessary-lambda-assignment,
    wrong-import-position,
    import-outside-toplevel,
    logging-fstring-interpolation,
    logging-not-lazy,
    too-many-statements,
    too-many-branches,
    too-many-instance-attributes,
    no-else-return,
    no-else-continue,
    unused-argument,
    unused-variable,
    unused-import,
    dangerous-default-value,
    consider-iterating-dictionary,
    unspecified-encoding,
    unnecessary-pass,
    consider-using-enumerate,
    unnecessary-else-return,
    too-many-public-methods,
    too-many-lines,
    redefined-builtin,
    broad-except,
    bare-except,
    eval-used,
    exec-used,
    duplicate-string-formatting-argument,
    bad-whitespace,
    trailing-whitespace,
    trailing-newlines,
    mixed-indentation,
    bad-continuation,
    anomalous-backslash-in-string,
    deprecated-method,
    deprecated-module,
    deprecated-class,
    deprecated-decorator,
    deprecated-argument

[BASIC]
good-names=P,R,K,x,z,i,j,k,idx,t,u,v,w,s,fp,fig,ax,plt
